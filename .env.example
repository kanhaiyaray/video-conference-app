# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ─── ZegoCloud credentials (https://console.zegocloud.com) ───────────────────
# Used by the local token server (server/token-server.js) AND
# by the Vercel serverless function (api/token.js) in production.
ZEGO_APP_ID=your_app_id_here
ZEGO_SERVER_SECRET=your_server_secret_here

# ─── Token server URL (frontend) ─────────────────────────────────────────────
# Local dev → http://localhost:3001
# Production on Vercel → leave EMPTY (frontend calls /api/token same-origin)
VITE_TOKEN_SERVER_URL=http://localhost:3001

# ─── Local token server port ─────────────────────────────────────────────────
PORT=3001
